generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  VIEWER
}

enum DocumentType {
  TAX_CERTIFICATE
  REGISTRATION
  INSURANCE_POLICY
  OTHER
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  password              String
  role                  Role              @default(VIEWER)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @default(now()) @updatedAt
  
  // Relations
  createdBusinesses     Business[]        @relation("CreatedBy")
  updatedBusinesses     Business[]        @relation("UpdatedBy")
  uploadedDocuments     Document[]        @relation("UploadedBy")
  statusChanges         StatusHistory[]   @relation("ChangedBy")
}

model Business {
  id                String              @id @default(uuid())
  name              String
  taxId             String
  country           String              // ISO 2-letter code
  industry          String
  status            BusinessStatus      @default(PENDING)
  riskScore         Int                 @default(0)
  
  createdById       String
  createdBy         User                @relation("CreatedBy", fields: [createdById], references: [id])
  
  updatedById       String?
  updatedBy         User?               @relation("UpdatedBy", fields: [updatedById], references: [id])
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  documents         Document[]
  statusHistory     StatusHistory[]
  riskCalculations  RiskCalculation[]
  
  @@unique([taxId, country])  // Same taxId allowed across countries, but not within same country
  @@index([status])
  @@index([country])
  @@index([riskScore])
}

model Document {
  id            String        @id @default(uuid())
  type          DocumentType
  filename      String
  url           String        // Public URL or presigned URL
  s3Key         String        // S3 object key for retrieval
  
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  uploadedById  String
  uploadedBy    User          @relation("UploadedBy", fields: [uploadedById], references: [id])
  
  createdAt     DateTime      @default(now())
  deletedAt     DateTime?     // Soft delete
  
  @@index([businessId])
  @@index([deletedAt])
}

model StatusHistory {
  id            String          @id @default(uuid())
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  status        BusinessStatus  // The status it changed TO
  
  changedById   String
  changedBy     User            @relation("ChangedBy", fields: [changedById], references: [id])
  
  reason        String?         // Optional comment on why status changed
  createdAt     DateTime        @default(now())
  
  @@index([businessId])
  @@index([createdAt])
}

model RiskCalculation {
  id                String      @id @default(uuid())
  businessId        String
  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  totalScore        Int         // 0-100
  countryRisk       Int         // Points from country
  industryRisk      Int         // Points from industry
  documentRisk      Int         // Points from missing docs
  
  metadata          Json?       // { high_risk_country: true, missing_docs: ['INSURANCE_POLICY'], etc }
  
  createdAt         DateTime    @default(now())
  
  @@index([businessId])
  @@index([createdAt])
}
